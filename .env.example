# Copy this file to apps/web/.env.local and fill in values.

# Anthropic API key — required for the AI chat
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to the compiled Rust MCP server binary.
# After running `pnpm build:mcp` (cargo build --release) the binary will be at:
#   apps/mcp-server/target/release/mcp-server
MCP_SERVER_PATH=./apps/mcp-server/target/release/mcp-server
