# Rename this file to .env.local and fill in real values before running.

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Full absolute path to the compiled Rust MCP binary.
# Build with: pnpm build:mcp  (runs cargo build --release)
MCP_SERVER_PATH=/absolute/path/to/apps/mcp-server/target/release/mcp-server
